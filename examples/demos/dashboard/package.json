{
  "name": "webstir-demo-dashboard",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Webstir HTML-first dashboard proof demo",
  "dependencies": {
    "@webstir-io/webstir-testing": "workspace:*",
    "@webstir-io/webstir-frontend": "workspace:*",
    "@webstir-io/webstir-backend": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "autoprefixer": "^10.4.20",
    "esbuild": "^0.25.0",
    "typescript": "^5.4.0"
  },
  "packageManager": "bun@1.3.5",
  "browserslist": [
    "last 2 chrome versions",
    "last 2 firefox versions",
    "last 2 safari major versions",
    "iOS >= 14",
    "not dead"
  ],
  "webstir": {
    "mode": "full",
    "moduleManifest": {},
    "enable": {
      "clientNav": true
    }
  }
}
