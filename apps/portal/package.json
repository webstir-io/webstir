{
  "name": "webstir-portal",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Documentation portal for the Webstir ecosystem.",
  "packageManager": "bun@1.3.11",
  "engines": {
    "node": ">=20.18",
    "bun": ">=1.3.11"
  },
  "scripts": {
    "start": "bun ../../packages/tooling/webstir-frontend/src/cli.ts build --workspace \"$PWD\"",
    "build": "bun ../../packages/tooling/webstir-frontend/src/cli.ts build --workspace \"$PWD\" && bun ../../packages/tooling/webstir-frontend/src/cli.ts publish --workspace \"$PWD\" --mode ssg",
    "publish": "bun ../../packages/tooling/webstir-frontend/src/cli.ts build --workspace \"$PWD\" && bun ../../packages/tooling/webstir-frontend/src/cli.ts publish --workspace \"$PWD\" --mode ssg"
  },
  "dependencies": {
    "@webstir-io/webstir-frontend": "workspace:*"
  },
  "devDependencies": {
    "typescript": "catalog:"
  },
  "webstir": {
    "mode": "ssg",
    "siteUrl": "https://webstir.io",
    "trailingSlash": false,
    "enable": {
      "clientNav": true,
      "search": true,
      "contentNav": true
    },
    "moduleManifest": {
      "views": [
        {
          "name": "HomeView",
          "path": "/"
        },
        {
          "name": "DocsView",
          "path": "/docs"
        },
        {
          "name": "NotFoundView",
          "path": "/404"
        }
      ]
    }
  }
}
